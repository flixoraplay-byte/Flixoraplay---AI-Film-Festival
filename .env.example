# FlixoraPlay Environment Variables

# JWT Secret for authentication (Required)
JWT_SECRET=your_jwt_secret_here

# Cloudflare D1 Local emulation DB binding is standard, no env var needed for local D1.
# TURSO (Optional - Remote DB Fallback)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Stripe (If used for payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google OAuth (If used)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
